# Environment — copy to .env and fill in your values

# -----------------------------------------------------------------------
# Security — REQUIRED: change before production
# -----------------------------------------------------------------------
SECRET_KEY=change-this-in-production-use-a-long-random-string
# Generate: openssl rand -hex 32

# -----------------------------------------------------------------------
# Admin user — created automatically on first run
# -----------------------------------------------------------------------
FIRST_ADMIN_EMAIL=admin@magnumai.io
FIRST_ADMIN_PASSWORD=changeme123!

# -----------------------------------------------------------------------
# OpenAI (optional — enables LLM-based detection)
# -----------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------
ENVIRONMENT=production
